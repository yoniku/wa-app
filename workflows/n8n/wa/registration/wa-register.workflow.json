      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\nconst persist = $input.first().json.body || $input.first().json || {};\nconst submit = $('Submit SMS OTP').first().json.body || $('Submit SMS OTP').first().json || {};\nconst registration = submit.registration || submit;\nconst loginState = persist.login_state || submit.login_state || {};\nconst submitStatus = registration.status || submit.status || '';\nconst submitOK = submit.success === true || ['REGISTRATION_STATUS_REGISTERED','REGISTERED','registered'].includes(submitStatus);\nconst persistOK = persist.success === true && ['LOGIN_STATE_STATUS_ACTIVE','ACTIVE','active'].includes(loginState.status || persist.status || '');\nconst ok = submitOK && persistOK;\nconst status = ok ? 'REGISTERED' : (submitOK ? 'LOGIN_STATE_PERSIST_FAILED' : 'OTP_SUBMIT_FAILED');\nconst message = ok ? '' : (persist.error_message || submit.error_message || persist.error?.message || submit.error?.message || 'registration login state is not active');\nconst proxy = { proxy_mode: 'US_RANDOM_DYNAMIC_IP', country_code: 'US' };\nreturn [{ json: { success: ok, status, error_message: message, phone: $('Normalize Registration Input').first().json.phone, wa_account_id: (($('Commit Fingerprint To Profile').first().json.body || $('Commit Fingerprint To Profile').first().json).wa_account_id || ''), client_profile_id: (($('Commit Fingerprint To Profile').first().json.body || $('Commit Fingerprint To Profile').first().json).client_profile_id || ''), registration, login_state: loginState, proxy } }];\n"
