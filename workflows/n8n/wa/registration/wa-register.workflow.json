      "parameters": {
        "mode": "runOnceForAllItems",
        "jsCode": "\nconst fallbackIsoByCallingCode = { '1': 'US', '20': 'EG', '44': 'GB', '49': 'DE', '55': 'BR', '62': 'ID', '63': 'PH', '65': 'SG', '66': 'TH', '84': 'VN', '90': 'TR', '91': 'IN', '92': 'PK', '212': 'MA', '234': 'NG', '971': 'AE' };\nfunction digits(value) { return String(value || '').replace(/\\D+/g, ''); }\nfunction clean(value) { return String(value || '').trim(); }\nfunction upper(value) { return clean(value).toUpperCase(); }\nfunction inferCountryFromDigits(value) {\n  const number = digits(value);\n  let best = { cc: '', iso: '' };\n  for (const [cc, iso] of Object.entries(fallbackIsoByCallingCode)) {\n    if (number.startsWith(cc) && cc.length > best.cc.length) best = { cc, iso };\n  }\n  return best;\n}\nconst body = $json.body || $json;\nconst phoneInput = (body.phone && typeof body.phone === 'object') ? body.phone : {};\nconst rawCountryCode = clean(body.country_code);\nconst countryCodeIsCalling = /^\\+?\\d+$/.test(rawCountryCode);\nlet cc = clean(phoneInput.country_calling_code || body.country_calling_code || body.cc || (countryCodeIsCalling ? rawCountryCode : '')).replace(/^\\+/, '');\nconst rawNational = phoneInput.national_number || body.national_number || (typeof body.phone === 'string' ? body.phone : '') || body.number || '';\nlet national = digits(rawNational);\nlet e164 = clean(phoneInput.e164_number || body.e164_number || '');\nif (!e164 && clean(rawNational).startsWith('+')) e164 = clean(rawNational);\nif (!e164 && cc && national) e164 = `+${cc}${national}`;\nif (e164 && !e164.startsWith('+')) e164 = `+${digits(e164)}`;\nconst inferred = e164.startsWith('+') ? inferCountryFromDigits(e164) : { cc, iso: fallbackIsoByCallingCode[cc] || '' };\nif (!cc && inferred.cc) cc = inferred.cc;\nif (e164.startsWith('+') && cc) national = digits(e164).slice(cc.length);\nconst regionCodeCountry = clean(body.region_code).includes('-') ? '' : body.region_code;\nconst countryIso = upper(phoneInput.country_iso2 || body.country_iso2 || body.country_region || regionCodeCountry || (!countryCodeIsCalling ? rawCountryCode : '') || inferred.iso || fallbackIsoByCallingCode[cc] || 'US');\nconst workspaceID = body.workspace_id || 'default';\nconst jobID = body.job_id || $execution.id;\nreturn [{ json: {\n  workspace_id: workspaceID,\n  job_id: jobID,\n  request_id: body.request_id || $execution.id,\n  actor_id: body.actor_id || '',\n  country_calling_code: cc,\n  country_code: cc,\n  country_iso2: countryIso,\n  country_region: countryIso,\n  region: countryIso,\n  phone: { e164_number: e164, country_calling_code: cc, national_number: national, country_iso2: countryIso },\n  include_transient_fingerprint: true,\n  purpose: 'WA_REGISTRATION',\n} }];\n"
      },
